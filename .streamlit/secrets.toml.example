# LLM provider API keys — copy this file to secrets.toml and fill in whichever
# provider(s) you have. secrets.toml is gitignored; this example file is not.
#
# Missing keys are skipped automatically. With no keys at all, the app still
# works and shows a deterministic, grounded (LLM-free) view; a key adds the
# narrated storytelling. Environment variables of the same name are used as a
# fallback (Docker / cloud).

# ANTHROPIC_API_KEY = "sk-ant-..."
# OPENAI_API_KEY    = "sk-..."
# GEMINI_API_KEY    = "..."
# DEEPSEEK_API_KEY  = "..."
